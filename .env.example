# GCN at ASU — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real credentials.

# ── Cal.com (Stage 8 — pending credentials) ──────────────────────────────
# Obtain from: https://cal.com/settings/developer/api-keys
CAL_COM_API_KEY=

# Cal.com booking URL slug (e.g. "gcn-asu/coffee-chat")
CAL_COM_BOOKING_SLUG=

# ── Email / form notifications (optional) ────────────────────────────────
# Used by app/api/join to email submissions to the exec board.
# Supported providers: Resend, SendGrid, Postmark — pick one.
EMAIL_FROM=
EMAIL_TO=
EMAIL_API_KEY=

# ── Rate limiter (production) ─────────────────────────────────────────────
# In production, replace the in-memory rate limiter in app/api/join/route.ts
# with a Redis-backed store (e.g. Upstash).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Deployment ────────────────────────────────────────────────────────────
# Set by Vercel/hosting provider automatically — do not set manually.
# NEXT_PUBLIC_VERCEL_URL=
